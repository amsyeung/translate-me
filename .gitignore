```gitignore
# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/

# Build output folders
dist/
dist-ssr/
build/
out/

# All environment secret files
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
*.env

# Local dev temporary files
*.local

# VS Code config (keep extensions.json only)
.vscode/*
!.vscode/extensions.json

# JetBrains IDE files
.idea/
*.iml
*.iws
*.ipr

# macOS system garbage
.DS_Store
._*
.AppleDouble
.LSOverride

# Windows system & editor files
Thumbs.db
desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.slnx
*.sw?
*.swp
*.bak

# Tool cache
.eslintcache
.cache/
.turbo

# Temporary files
*.tmp
*.temp
```